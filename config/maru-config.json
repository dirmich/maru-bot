{
  "project": "MaruMiniBot",
  "version": "1.0.0",
  "engine": "maruminibot",
  "hardware": {
    "gpio": {
      "enabled": true,
      "pins": {
        "led_status": 18,
        "button_action": 23
      }
    },
    "i2c": {
      "enabled": true,
      "sensors": ["BME280", "LUX"]
    },
    "multimedia": {
      "camera": "libcamera",
      "audio": {
        "input": "alsa",
        "output": "alsa"
      }
    }
  },
  "agents": {
    "defaults": {
      "model": "glm-4.7",
      "workspace": "./workspace",
      "max_tool_iterations": 25
    }
  },
  "tools": {
    "enabled": ["shell", "filesystem", "web", "gpio", "camera"]
  }
}
